<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">QuoteMatic</a>
    <nav class="nav-links" aria-label="Navegación principal">
      <% if (user.isAuthenticated) { %>
        <a href="/dashboard">Explorar frases</a>
        <a href="/favorites">Favoritos</a>
        <% if (user.role === "admin") { %>
          <a href="/admin">Admin</a>
          <a href="/api-docs">API Docs</a>
        <% } %>
        <form method="POST" action="/auth/logout" class="nav-form">
          <button class="button nav-button danger" type="submit">Cerrar sesión</button>
        </form>
      <% } else { %>
        <a class="button nav-button primary" href="/auth/login">Entrar</a>
      <% } %>
    </nav>
  </header>

  <% if (!isForbidden) { %>
    <%- include('partials/admin-subnav') %>
  <% } %>

  <main class="page-shell">
    <section class="panel">
      <p class="eyebrow">Rol admin</p>
      <h1>Panel admin</h1>

      <% if (isForbidden) { %>
        <p>No tienes permisos de admin para acceder a este panel.</p>
        <a class="button primary" href="/dashboard">Volver a explorar frases</a>
      <% } else { %>
        <p>Panel de administración para revisar datos y gestionar el contenido de QuoteMatic.</p>
      <% } %>
    </section>

    <% if (!isForbidden) { %>
      <section class="panel">
        <h2>Últimas frases activas</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Frase</th>
                <th>Autor</th>
                <th>Tipo</th>
                <th>Situación</th>
                <th>Rating</th>
              </tr>
            </thead>
            <tbody>
              <% quotes.forEach(function(quote) { %>
                <tr>
                  <td><%= quote.text %></td>
                  <td><%= quote.author.name %></td>
                  <td><%= quote.quoteType.name %></td>
                  <td><%= quote.situation.name %></td>
                  <td><%= quote.contentRating %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>
    <% } %>
  </main>
</body>
</html>
