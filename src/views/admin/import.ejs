<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <%- include('../partials/admin-nav') %>

  <main class="page-shell">

    <!-- ── Hero ───────────────────────────────────────────────────────────── -->
    <section class="panel">
      <p class="eyebrow">Importación asistida</p>
      <h1>Importar frases desde Quotable</h1>
      <p class="muted">
        Elige un autor sugerido o busca por nombre para revisar sus frases antes de importarlas.
      </p>
      <% if (msg) { %>
        <p class="status-message" style="margin-top:0.75rem;"
          data-type="<%= String(msg).startsWith('Error') ? 'error' : 'success' %>">
          <%= msg %>
        </p>
      <% } %>
    </section>

    <!-- ── Paso 1: búsqueda de autores ─────────────────────────────────────── -->
    <% if (step === 'search') { %>
      <section class="panel">
        <h2>Buscar autor</h2>

        <form method="POST" action="/admin/import/search" class="import-search-form">
          <label>
            Nombre del autor
            <input type="text" name="query" value="<%= query %>" required
              placeholder="Ej: Marcus Aurelius, Oscar Wilde, Albert Einstein..." />
          </label>
          <button class="button primary" type="submit">Buscar autores</button>
        </form>

        <% if (error) { %>
          <p class="error-message" style="margin-top:1rem;"><%= error %></p>
        <% } %>
      </section>

      <%-- Resultados de búsqueda (después de usar el formulario) --%>
      <% if (authors && authors.length > 0) { %>
        <section class="panel">
          <h2>Resultados de búsqueda (<%= authors.length %>)</h2>
          <div class="import-results">
            <% authors.forEach(function(author) { %>
              <article class="import-card">
                <div class="import-card-info">
                  <strong><%= author.name %></strong>
                  <% if (author.description) { %>
                    <p class="muted"><%= author.description %></p>
                  <% } %>
                  <% if (author.bio) { %>
                    <p class="muted" style="font-size:0.85rem;">
                      <%= author.bio.slice(0, 140) %><%= author.bio.length > 140 ? '…' : '' %>
                    </p>
                  <% } %>
                  <% if (author.quoteCount) { %>
                    <span class="badge"><%= author.quoteCount %> frases</span>
                  <% } %>
                </div>
                <a class="button primary small"
                  href="/admin/import/quotes/<%= encodeURIComponent(author.slug) %>?name=<%= encodeURIComponent(author.name) %>">
                  Ver frases
                </a>
              </article>
            <% }); %>
          </div>
        </section>
      <% } %>

      <%-- Autores sugeridos (cargados en la carga inicial de la página) --%>
      <% if (suggestedAuthors && suggestedAuthors.length > 0) { %>
        <section class="panel">
          <h2>Autores sugeridos</h2>
          <p class="muted" style="margin-bottom:1rem;">
            Los autores con más frases disponibles en Quotable.
          </p>
          <div class="import-results">
            <% suggestedAuthors.forEach(function(author) { %>
              <article class="import-card">
                <div class="import-card-info">
                  <strong><%= author.name %></strong>
                  <% if (author.description) { %>
                    <p class="muted"><%= author.description %></p>
                  <% } %>
                  <% if (author.bio) { %>
                    <p class="muted" style="font-size:0.85rem;">
                      <%= author.bio.slice(0, 140) %><%= author.bio.length > 140 ? '…' : '' %>
                    </p>
                  <% } %>
                  <% if (author.quoteCount) { %>
                    <span class="badge"><%= author.quoteCount %> frases</span>
                  <% } %>
                </div>
                <a class="button primary small"
                  href="/admin/import/quotes/<%= encodeURIComponent(author.slug) %>?name=<%= encodeURIComponent(author.name) %>">
                  Ver frases
                </a>
              </article>
            <% }); %>
          </div>
        </section>
      <% } else if (suggestedError) { %>
        <p class="muted" style="margin-top:0.5rem;font-size:0.9rem;"><%= suggestedError %></p>
      <% } %>
    <% } %>

    <!-- ── Paso 2: frases del autor con checkboxes ──────────────────────────── -->
    <% if (step === 'quotes') { %>
      <section class="panel">
        <div class="panel-heading">
          <div>
            <h2>Frases de: <em><%= authorName %></em></h2>
            <p class="muted">Selecciona las frases que quieres importar a QuoteMatic.</p>
          </div>
          <a class="button" href="/admin/import">← Buscar otro autor</a>
        </div>

        <% if (error) { %>
          <p class="error-message" style="margin-top:1rem;"><%= error %></p>
        <% } %>

        <% if (quotes && quotes.length > 0) { %>
          <form method="POST" action="/admin/import/quotes" style="margin-top:1.25rem;">
            <input type="hidden" name="authorSlug" value="<%= authorSlug %>" />
            <input type="hidden" name="authorName" value="<%= authorName %>" />

            <div class="import-results">
              <% quotes.forEach(function(quote) { %>
                <label class="import-quote-item">
                  <input type="checkbox" name="selectedIds" value="<%= quote._id %>" />
                  <div class="import-card-info">
                    <span style="font-weight:600;font-size:0.97rem;">"<%= quote.content %>"</span>
                    <% if (quote.tags && quote.tags.length > 0) { %>
                      <div style="display:flex;flex-wrap:wrap;gap:0.35rem;margin-top:0.4rem;">
                        <% quote.tags.forEach(function(tag) { %>
                          <span class="badge"><%= tag %></span>
                        <% }); %>
                      </div>
                    <% } %>
                  </div>
                </label>
              <% }); %>
            </div>

            <div class="button-row" style="margin-top:1.5rem;">
              <button class="button primary" type="submit">Importar seleccionadas</button>
              <a class="button" href="/admin/import">Cancelar</a>
            </div>
          </form>
        <% } %>
      </section>
    <% } %>

    <!-- ── Paso 3: resumen de importación ──────────────────────────────────── -->
    <% if (step === 'done' && importSummary) { %>
      <section class="panel">
        <h2>Importación completada</h2>

        <div class="import-summary">
          <p>
            <strong>Autor:</strong> <%= importSummary.authorName %>
            <% if (importSummary.authorCreated) { %>
              <span class="badge badge-active">creado</span>
            <% } else { %>
              <span class="badge">ya existía</span>
            <% } %>
          </p>
          <p><strong>Frases importadas:</strong> <%= importSummary.quotesCreated %></p>
          <p><strong>Duplicadas omitidas:</strong> <%= importSummary.duplicatesSkipped %></p>
          <% if (importSummary.errors && importSummary.errors.length > 0) { %>
            <p><strong>Errores (<%= importSummary.errors.length %>):</strong></p>
            <ul class="muted">
              <% importSummary.errors.forEach(function(e) { %>
                <li><%= e %></li>
              <% }); %>
            </ul>
          <% } %>
        </div>

        <div class="button-row" style="margin-top:1.5rem;">
          <a class="button primary" href="/admin/quotes">Ver frases</a>
          <a class="button" href="/admin/authors">Ver autores</a>
          <a class="button" href="/admin/import">Importar más</a>
        </div>
      </section>
    <% } %>

  </main>
</body>
</html>
