<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="landing">
    <section class="card">
      <p class="eyebrow">QuoteMatic Auth</p>
      <h1>Crear cuenta</h1>

      <% if (error) { %>
        <p><%= error %></p>
      <% } %>

      <form method="POST" action="/auth/register">
        <div>
          <label for="name">Nombre</label>
          <input id="name" name="name" type="text" required />
        </div>

        <div>
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required />
        </div>

        <div>
          <label for="password">Contraseña</label>
          <input id="password" name="password" type="password" required />
        </div>

        <div>
          <label for="ageRange">Rango de edad</label>
          <select id="ageRange" name="ageRange" required>
            <option value="">Selecciona una opción</option>
            <option value="under_14">Menor de 14 años</option>
            <option value="teen_14_17">Entre 14 y 17 años</option>
            <option value="adult_18_plus">18 años o más</option>
          </select>
        </div>

        <button type="submit">Registrarme</button>
      </form>

      <div class="actions">
        <a href="/">Volver al inicio</a>
      </div>
    </section>
  </main>
</body>
</html>