<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">QuoteMatic</a>
    <nav class="nav-links" aria-label="Navegación principal">
      <a class="button nav-button primary" href="/auth/login">Entrar</a>
    </nav>
  </header>

  <main class="landing">
    <section class="card auth-card">
      <p class="eyebrow">QuoteMatic Auth</p>
      <h1>Crear cuenta</h1>

      <% if (error) { %>
        <p class="error-message"><%= error %></p>
      <% } %>

      <form method="POST" action="/auth/register">
        <div>
          <label for="name">Nombre</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>

        <div>
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>

        <div>
          <label for="password">Contraseña</label>
          <input id="password" name="password" type="password" required autocomplete="new-password" />
        </div>

        <div>
          <label for="ageRange">Rango de edad</label>
          <select id="ageRange" name="ageRange" required>
            <option value="">Selecciona una opción</option>
            <option value="under_14">Menor de 14 años</option>
            <option value="teen_14_17">Entre 14 y 17 años</option>
            <option value="adult_18_plus">18 años o más</option>
          </select>
        </div>

        <button class="button primary" type="submit">Registrarme</button>
      </form>

      <p class="auth-hint">¿Ya tienes cuenta? <a href="/auth/login">Iniciar sesión</a></p>
    </section>
  </main>
</body>
</html>
